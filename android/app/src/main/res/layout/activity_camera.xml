<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Camera feed -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Face bounding box overlay -->
    <com.khozy.emotion.DrawingOverlayView
        android:id="@+id/cameraOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top toolbar: switch + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/switchCameraButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Rear"
            android:textColor="@android:color/white"
            app:strokeColor="@android:color/white" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textColor="@android:color/white"
            app:strokeColor="@android:color/white" />
    </LinearLayout>

    <!-- Bottom result card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <!-- Emoji + emotion label -->
        <TextView
            android:id="@+id/tvEmojiLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starting camera…"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Confidence percentage -->
        <TextView
            android:id="@+id/tvConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <!-- Confidence progress bar -->
        <ProgressBar
            android:id="@+id/progressConfidence"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#44FFFFFF" />

        <!-- Per-emotion breakdown -->
        <TextView
            android:id="@+id/tvBreakdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</FrameLayout>